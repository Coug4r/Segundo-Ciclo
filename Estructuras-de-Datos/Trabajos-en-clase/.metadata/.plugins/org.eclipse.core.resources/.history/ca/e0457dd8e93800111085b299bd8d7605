package buffering;

import java.io.BufferedOutputStream;
import java.io.FileOutputStream;
import java.io.IOException;
import java.util.Scanner;
public class bufferInput {
	public static void main(String args[]) {
		Scanner sc = new Scanner(System.in);
		try(BufferedOutputStream myBufferedOutputStream = new BufferedOutputStream(new FileOutputStream("C:\\Users\\nasnd\\OneDrive\\Desktop\\ejercicio1.txt"))){
			System.out.println("¿Que carrera estudias?");
			String data1 ="Carrera: "+ sc.nextLine();
			System.out.println("¿Cuantos años dura?");
			data1 += " Duracion: " +sc.nextLine() + " anios";
			
			byte b1[] = data1.getBytes();
			myBufferedOutputStream.write(b1);
		}catch(IOException e) {
			System.err.println("Error de escritura en archivo");
		}
	}
}
